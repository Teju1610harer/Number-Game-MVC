<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Number Game</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

    <style>

        /* ===== GLOBAL THEME ===== */

        body {
            font-family: 'Poppins',sans-serif;
            background: #f4f6f8;
            margin: 0;
            color: #111827;
        }

        /* NAVBAR */
        .navbar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
        }

        .navbar-brand {
            font-weight: 700;
            color: #2563eb !important;
        }

        /* CENTER PAGE */
        .container {
            min-height: 85vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* CARD STYLE */
        .game-card,
        .leader-card {
            background: white;
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 3px 10px rgba(0,0,0,.08);
            border: 1px solid #e5e7eb;
        }

        /* BUTTON */
        .btn-theme {
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 6px;
        }

            .btn-theme:hover {
                background: #1d4ed8;
                color: white;
            }

        /* INPUT */
        .form-control {
            border-radius: 6px;
            border: 1px solid #d1d5db;
        }

            .form-control:focus {
                border-color: #2563eb;
                box-shadow: none;
            }

        /* STAT BOX */
        .stat-box {
            background: #f9fafb;
            border-radius: 8px;
            padding: 12px;
            border: 1px solid #e5e7eb;
        }

        /* TABLE */
        .table {
            color: #111;
        }

        .gold {
            background: #fff7cc;
        }

        .silver {
            background: #f1f5f9;
        }

        .bronze {
            background: #ffe4e6;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar px-4">
        <a class="navbar-brand" href="/Home/Index">
            🎯 Number Game
        </a>

        <div class="ms-auto">
            <a href="/Home/Leaderboard" class="btn btn-theme">
                🏆 Leaderboard
            </a>
        </div>
    </nav>

    <!-- BODY -->
    <div class="container">
        @RenderBody()
    </div>


    <audio id="winSound"
           src="https://assets.mixkit.co/sfx/preview/mixkit-arcade-game-complete-or-approved-mission-205.wav"></audio>

    <audio id="failSound"
           src="https://assets.mixkit.co/sfx/preview/mixkit-player-losing-or-failing-2042.wav"></audio>
</body>
</html>