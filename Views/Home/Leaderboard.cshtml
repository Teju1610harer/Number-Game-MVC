@model IEnumerable<MVC_NumberGame.Models.GameResult>

<div class="leader-card" style="width:900px;">

    <h3 class="text-center mb-4">🏆 Global Leaderboard</h3>

    <table class="table text-center">

        <thead>
            <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Guess</th>
                <th>Attempts</th>
                <th>Date</th>
            </tr>
        </thead>

        <tbody>

            @{
                int rank = 1;
            }

            @foreach (var item in Model)
            {
                string rowClass = "";

                if (rank == 1) { rowClass = "gold"; }
                else if (rank == 2) { rowClass = "silver"; }
                else if (rank == 3) { rowClass = "bronze"; }

                <tr class="@rowClass">
                    <td>#@rank</td>
                    <td>@item.PlayerName</td>
                    <td>@item.GuessNumber</td>
                    <td>@item.Attempts</td>
                    <td>@item.ResultDate.ToShortDateString()</td>
                </tr>

                rank++;
            }

        </tbody>

    </table>

    <a href="/Home/Index" class="btn btn-theme w-100 mt-3">
        🎮 Play Again
    </a>

</div>